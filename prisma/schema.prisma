generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailyGame {
  id           String   @id @default(cuid())
  dateKey      String   @unique
  theme        String
  specialLabel String
  specialHint  String
  createdAt    DateTime @default(now())

  objects      GameObject[]
}

model GameObject {
  id        String   @id @default(cuid())
  name      String
  oldest    Int
  largest   Int
  value     Int
  influence Int

  employees Int
  users     Int
  marketCap Int
  patents   Int

  dailyGames DailyGame[]
}
